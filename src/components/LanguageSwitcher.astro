---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { IoLanguage } from "react-icons/io5";
import { IoMdArrowDropdown } from "react-icons/io";

const { pathname } = new URL(Astro.request.url);
const locales = ["ja", "en"];
const currentLang = locales.find(lang => pathname.startsWith(`/${lang}`)) ?? locales[0];
const sortedLocales = [currentLang, ...locales.filter(lang => lang !== currentLang)];

const basePath = pathname.replace(
  new RegExp(`^\/(${locales.join("|")})`), ""
) || "/";

---
<div class="lang-switcher">
  <IoLanguage />
  <span class="lang-label">
    {currentLang === "en" ? "English" : "日本語"}
  </span>
  <IoMdArrowDropdown />

  <select
    class="lang-switcher-select"
    name="language"
    aria-label="Select language"
  >
    {sortedLocales.map((lang) => {
      const url = getRelativeLocaleUrl(lang, basePath);
      return (
        <option
          value={url}
          selected={lang === currentLang}
        >
          {lang === "en" ? "English" : "日本語"}
        </option>
      );
    })}
  </select>
</div>

<script>
  document.querySelectorAll(".lang-switcher-select").forEach((element) => {
    if (!(element instanceof HTMLSelectElement) || element.dataset.bound === "true") {
      return;
    }

    element.dataset.bound = "true";
    element.addEventListener("change", () => {
      const nextUrl = element.value;
      const locale = nextUrl.startsWith("/ja") ? "ja" : "en";
      window.localStorage.setItem("preferred-locale", locale);
      window.location.href = nextUrl;
    });
  });
</script>

<style>
.lang-switcher {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: .25rem;
  padding: .25rem .5rem;
  border: 1px solid #ccc;
  border-radius: 4px;
  background: #fff;
  font-size: .875rem;
}

.lang-switcher svg, .lang-label {
  z-index: 1;
  pointer-events: none;
}

.lang-switcher-select {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  opacity: 0;
  cursor: pointer;
}
</style>
